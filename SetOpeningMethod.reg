; 新建 ProgID: ASFFile
[HKEY_CLASSES_ROOT\ASFFile]
@="Windows Media 音频/视频文件"
[HKEY_CLASSES_ROOT\ASFFile\DefaultIcon]
@="C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe,-120"
[HKEY_CLASSES_ROOT\ASFFile\shell]
@="play"
[HKEY_CLASSES_ROOT\ASFFile\shell\open]
@="打开(&O)"
[HKEY_CLASSES_ROOT\ASFFile\shell\open\command]
@="\"C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe\"  /Open \"%L\""
[HKEY_CLASSES_ROOT\ASFFile\shell\play]
@="播放(&P)"
[HKEY_CLASSES_ROOT\ASFFile\shell\play\command]
@="\"C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe\"  /Play \"%L\""

