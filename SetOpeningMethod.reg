Windows Registry Editor Version 5.00

; 文件扩展名关联
[HKEY_CLASSES_ROOT\.aac]
@="AACFile"

[HKEY_CLASSES_ROOT\.aif]
@="AIFFFile"

[HKEY_CLASSES_ROOT\.aifc]
@="AIFFFile"

[HKEY_CLASSES_ROOT\.aiff]
@="AIFFFile"

[HKEY_CLASSES_ROOT\.au]
@="AUFile"

[HKEY_CLASSES_ROOT\.avi]
@="avifile"

[HKEY_CLASSES_ROOT\.cda]
@="CDAFile"

[HKEY_CLASSES_ROOT\.mp2]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mp2v]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mp3]
@="mp3file"

[HKEY_CLASSES_ROOT\.mpa]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mpe]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mpeg]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mpg]
@="mpegfile"

[HKEY_CLASSES_ROOT\.mpv2]
@="mpegfile"

[HKEY_CLASSES_ROOT\.snd]
@="AUFile"

[HKEY_CLASSES_ROOT\.wav]
@="soundrec"

[HKEY_CLASSES_ROOT\.wmv]
@="WMVFile"

[HKEY_CLASSES_ROOT\.wmx]
@="ASXFile"

[HKEY_CLASSES_ROOT\.wax]
@="WAXFile"

[HKEY_CLASSES_ROOT\.wma]
@="wmafile"

[HKEY_CLASSES_ROOT\.wmd]
@="WMDFile"

[HKEY_CLASSES_ROOT\.wmdb]
@="WMP.WMDBFile"

[HKEY_CLASSES_ROOT\.wmz]
@="WMZFile"

[HKEY_CLASSES_ROOT\.wms]
@="WMSFile"

[HKEY_CLASSES_ROOT\.asx]
@="ASXFile"

[HKEY_CLASSES_ROOT\.m1v]
@="mpegfile"

[HKEY_CLASSES_ROOT\.m3u]
@="m3ufile"

[HKEY_CLASSES_ROOT\.wm]
@="ASFFile"

; 修改现有 ProgID 的命令和图标（指向 x86 路径）
; AIFFFile
[HKEY_CLASSES_ROOT\AIFFFile\DefaultIcon]
@="C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe,-120"
[HKEY_CLASSES_ROOT\AIFFFile\shell]
@="play"
[HKEY_CLASSES_ROOT\AIFFFile\shell\open\command]
@="\"C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe\"  /Open \"%L\""
[HKEY_CLASSES_ROOT\AIFFFile\shell\play\command]
@="\"C:\\Program Files (x86)\\Windows Media Player\\wmplayer.exe\"  /Play \"%L\""

