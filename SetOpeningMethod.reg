; ========== 뿟릿 AudioCD 뵨 DVD ==========

[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\AudioCD]
@="AudioCD"
"EditFlags"=hex:02,00,10,00
[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\AudioCD\DefaultIcon]
@="%SystemRoot%\\System32\\wmploc.dll,-200"
[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\AudioCD\shell\play\command]
@="\"%ProgramFiles%\\Windows Media Player\\wmplayer.exe\" /play \"%L\""

[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\DVD]
@="DVD"
"EditFlags"=hex:02,00,10,00
[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\DVD\DefaultIcon]
@="%SystemRoot%\\System32\\wmploc.dll,-200"
[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\DVD\shell\play\command]
@="\"%ProgramFiles%\\Windows Media Player\\wmplayer.exe\" /play \"%L\""