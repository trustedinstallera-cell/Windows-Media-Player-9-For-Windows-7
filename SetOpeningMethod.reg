@="%ProgramFiles%\\Windows Media Player\\wmplayer.exe,0"
[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\WMP11.AssocFile.MOV\shell\open\command]
@="\"%ProgramFiles%\\Windows Media Player\\wmplayer.exe\" \"%1\""

